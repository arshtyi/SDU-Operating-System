CompileFlags:
    Add:
        - -Wall
        - -Wextra
        - -Wpedantic
        - -Wshadow
        - -Wconversion
        - -Wsign-conversion
        - -Wnon-virtual-dtor
        - -Wold-style-cast
        - -std=c++20
    Remove:
        - -W*

Diagnostics:
    ClangTidy:
        Add:
            - bugprone-*
            - performance-*
            - readability-*
            - modernize-*
            - cppcoreguidelines-*
        Remove:
            - modernize-use-trailing-return-type
            - readability-magic-numbers
            - cppcoreguidelines-avoid-magic-numbers
            - cppcoreguidelines-pro-bounds-array-to-pointer-decay
            - cppcoreguidelines-pro-type-vararg
            - cppcoreguidelines-owning-memory

Completion:
    AllScopes: true

InlayHints:
    Enabled: true
    ParameterNames: true
    DeducedTypes: true
    Designators: true
